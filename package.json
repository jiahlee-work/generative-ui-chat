{
  "name": "generative-ui-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:prompt": "node scripts/generate-openui-prompt.mjs",
    "dev": "pnpm generate:prompt && next dev",
    "build": "pnpm generate:prompt && next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "prepare": "husky"
  },
  "dependencies": {
    "@openuidev/react-headless": "^0.8.2",
    "@openuidev/react-ui": "^0.11.8",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@openuidev/cli": "^0.0.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
